{
  "name": "finance-calculator-pro",
  "version": "1.1.0",
  "author": "boffincoders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boffincoders/finance-calculator.git"
  },
  "bugs": {
    "url": "https://github.com/boffincoders/finance-calculator/issues"
  },
  "homepage": "https://boffincoders.github.io/finance-calculator/",
  "description": "Zero-dependency financial analysis engine for JavaScript/TypeScript. Calculates 30+ metrics: P/E, P/B, EV/EBITDA, ROE, Altman Z-Score, Piotroski F-Score, DCF, Graham Number, Sharpe Ratio and more. Works with yahoo-finance2 and any data source.",
  "keywords": [
    "finance",
    "financial-ratios",
    "financial-analysis",
    "financial-calculator",
    "financial-metrics",
    "valuation",
    "fundamental-analysis",
    "stock-analysis",
    "stock-screener",
    "investment-analysis",
    "equity-analysis",
    "pe-ratio",
    "price-to-earnings",
    "price-to-book",
    "price-to-sales",
    "ev-ebitda",
    "enterprise-value",
    "dcf",
    "discounted-cash-flow",
    "graham-number",
    "altman-z-score",
    "piotroski",
    "piotroski-f-score",
    "sharpe-ratio",
    "roa",
    "roe",
    "roic",
    "profit-margin",
    "liquidity-ratio",
    "debt-to-equity",
    "solvency",
    "portfolio-analysis",
    "typescript",
    "zero-dependency"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.1"
  }
}
